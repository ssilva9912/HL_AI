HOMELAB_API_HOST=127.0.0.1
HOMELAB_API_PORT=8000
HOMELAB_API_URL=http://127.0.0.1:8000

HOMELAB_OLLAMA_URL=http://localhost:11434
HOMELAB_LLM_MODEL=llama3.2
HOMELAB_EMBEDDING_MODEL=nomic-embed-text

HOMELAB_REQUEST_TIMEOUT=120
HOMELAB_EMBEDDING_TIMEOUT=30
HOMELAB_DEFAULT_TOP_K=5
HOMELAB_MAX_UPLOAD_BYTES=10485760

HOMELAB_DOCUMENT_DIRECTORY=data/documents
HOMELAB_VECTOR_STORE_PATH=data/index/qdrant
HOMELAB_VECTOR_COLLECTION_NAME=homelab_documents

POSTGRES_DB=homelab_ai
POSTGRES_USER=homelab_ai
POSTGRES_PASSWORD=replace_with_a_random_local_password

HOMELAB_DATABASE_URL=postgresql+psycopg://homelab_ai:replace_with_a_random_local_password@localhost:5432/homelab_ai
HOMELAB_DATABASE_ECHO=false